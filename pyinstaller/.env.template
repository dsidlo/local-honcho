# Honcho Pi Configuration
# Generated by {{ project_name }} v{{ version }}
# Last Updated: {{ timestamp }}

# =============================================================================
# CORE APPLICATION SETTINGS
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL={{ log_level | default('INFO') }}

# Honcho API server port (default: 8300)
HONCHO_PORT={{ honcho_port | default(8300) }}

# Application namespace for multi-tenant deployments
NAMESPACE={{ namespace | default('honcho') }}

# Installation paths (set by PyApp at runtime)
PYAPP_INSTALL_DIR={{ install_dir | default('~/.local/share/honcho-pi') }}
PYAPP_CONFIG_DIR={{ config_dir | default('~/.config/honcho-pi') }}

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL connection URI with pgvector (required)
# Default uses port 5432 (standard PostgreSQL port)
HONCHO_DB_CONNECTION_URI={{ honcho_db_connection_uri | default('postgresql+psycopg://honcho:honcho@localhost:5432/honcho') }}

# Database schema
DB_SCHEMA={{ db_schema | default('public') }}

# Connection pool settings
DB_POOL_SIZE={{ db_pool_size | default(10) }}
DB_MAX_OVERFLOW={{ db_max_overflow | default(20) }}
DB_POOL_TIMEOUT={{ db_pool_timeout | default(30) }}
DB_POOL_RECYCLE={{ db_pool_recycle | default(300) }}
DB_POOL_USE_LIFO={{ db_pool_use_lifo | default(true) | lower }}
DB_SQL_DEBUG={{ db_sql_debug | default(false) | lower }}

# =============================================================================
# LLM PROVIDER CONFIGURATION
# =============================================================================

# Default LLM Provider: anthropic, openai, gemini, groq, vllm
# From .env: DERIVER uses vllm, DREAM uses anthropic
LLM_PROVIDER={{ llm_provider | default('vllm') }}

# --- Anthropic ---
LLM_ANTHROPIC_API_KEY={{ llm_anthropic_api_key | default('sk-ant-xxxxx') }}

# --- OpenAI ---
LLM_OPENAI_API_KEY={{ llm_openai_api_key | default('sk-xxxxxxxxxxxxx') }}
LLM_OPENAI_ORG_KEY={{ llm_openai_org_key | default('') }}

# --- Gemini ---
LLM_GEMINI_API_KEY={{ llm_gemini_api_key | default('AIzaSyxxxxxxxxxxxxx') }}

# --- Groq ---
LLM_GROQ_API_KEY={{ llm_groq_api_key | default('gsk_xxxxxxxxxxxxx') }}

# --- vLLM (Self-hosted) ---
# From .env: Base URL points to Ollama-compatible endpoint
LLM_VLLM_BASE_URL={{ llm_vllm_base_url | default('http://localhost:11434/v1') }}
LLM_VLLM_API_KEY={{ llm_vllm_api_key | default('not-needed') }}

# --- Ollama (Local) ---
LLM_OLLAMA_BASE_URL={{ llm_ollama_base_url | default('http://localhost:11434') }}
LLM_OLLAMA_EMBEDDING_MODEL={{ llm_ollama_embedding_model | default('bge-m3') }}

# General LLM settings
LLM_DEFAULT_MAX_TOKENS={{ llm_default_max_tokens | default(2500) }}
LLM_MAX_TOOL_OUTPUT_CHARS={{ llm_max_tool_output_chars | default(10000) }}
LLM_MAX_MESSAGE_CONTENT_CHARS={{ llm_max_message_content_chars | default(2000) }}
LLM_EMBEDDING_PROVIDER={{ llm_embedding_provider | default('openai') }}

# =============================================================================
# DERIVER CONFIGURATION (Background Memory Processing)
# =============================================================================

DERIVER_ENABLED={{ deriver_enabled | default(true) | lower }}

# Number of Deriver workers
DERIVER_WORKERS={{ deriver_workers | default(8) }}

# From .env: DERIVER uses vllm with kimi-k2.5
DERIVER_PROVIDER={{ deriver_provider | default('vllm') }}
DERIVER_MODEL={{ deriver_model | default('kimi-k2.5') }}

# Deriver behavior
DERIVER_DEDUPLICATE={{ deriver_deduplicate | default(true) | lower }}
DERIVER_FLUSH_ENABLED={{ deriver_flush_enabled | default(true) | lower }}
DERIVER_MAX_OUTPUT_TOKENS={{ deriver_max_output_tokens | default(4096) }}
DERIVER_THINKING_BUDGET_TOKENS={{ deriver_think_tokens | default(2048) }}
DERIVER_MAX_INPUT_TOKENS={{ deriver_max_input_tokens | default(23000) }}
DERIVER_WORKER_REPRESENTATION_MAX_OBSERVATIONS={{ deriver_working_rep_max | default(100) }}

# Processing intervals
DERIVER_POLLING_SLEEP_INTERVAL_SECONDS={{ deriver_poll_interval | default(1.0) }}
DERIVER_STALE_SESSION_TIMEOUT_MINUTES={{ deriver_stale_timeout | default(5) }}

# Retry configuration
DERIVER_RETRY_MAX_RETRIES={{ deriver_retry_max | default(3) }}
DERIVER_RETRY_BASE_BACKOFF_SEC={{ deriver_retry_backoff | default(5.0) }}
DERIVER_RETRY_MAX_BACKOFF_SEC={{ deriver_retry_max_backoff | default(300.0) }}
DERIVER_RETRY_ERROR_TRACKER_TTL_SEC={{ deriver_retry_ttl | default(3600.0) }}

# =============================================================================
# DERIVER WEIGHTED ROUND-ROBIN (WRR) CONFIGURATION
# =============================================================================

DERIVER_WRR_ENABLED={{ deriver_wrr_enabled | default(true) | lower }}

# Task type weights - must sum to exactly 1.0 (100%)
# From .env: representation=0.50, summary=0.15, webhook=0.08, dream=0.05, reconciler=0.07, idle_fill=0.15
DERIVER_WRR_WEIGHTS={{ deriver_wrr_weights | default('{"representation":0.50,"summary":0.15,"webhook":0.08,"dream":0.05,"reconciler":0.07,"idle_fill":0.15}') }}

# Minimum guaranteed slots per poll (prevents starvation)
DERIVER_WRR_MIN_SLOTS={{ deriver_wrr_min_slots | default('{"representation":3,"summary":1,"webhook":1,"dream":1,"reconciler":1,"idle_fill":0}') }}

# Maximum slots per type (null means no cap)
DERIVER_WRR_MAX_SLOTS={{ deriver_wrr_max_slots | default('{"representation":null,"summary":null,"webhook":null,"dream":null,"reconciler":3,"idle_fill":null}') }}

DERIVER_WRR_IDLE_FILL_STRATEGY={{ deriver_wrr_idle_fill_strategy | default('oldest_first') }}
DERIVER_WRR_METRICS_ENABLED={{ deriver_wrr_metrics_enabled | default(true) | lower }}
DERIVER_WRR_DEBUG_LOGGING={{ deriver_wrr_debug_logging | default(false) | lower }}

# =============================================================================
# DIALECTIC CONFIGURATION (Chat/Memory API)
# =============================================================================

DIALECTIC_MAX_OUTPUT_TOKENS={{ dialectic_max_tokens | default(8192) }}
DIALECTIC_MAX_INPUT_TOKENS={{ dialectic_max_input_tokens | default(100000) }}
DIALECTIC_HISTORY_TOKEN_LIMIT={{ dialectic_history_limit | default(8192) }}
DIALECTIC_SESSION_HISTORY_MAX_TOKENS={{ dialectic_session_history | default(4096) }}

# Reasoning Levels (minimal, low, medium, high, max)
# Uses nested delimiter __ for hierarchical config

# Minimal: Fastest, minimal thinking
DIALECTIC_LEVELS__MINIMAL__PROVIDER={{ dialectic_minimal_provider | default('vllm') }}
DIALECTIC_LEVELS__MINIMAL__MODEL={{ dialectic_minimal_model | default('kimi-k2.5') }}
DIALECTIC_LEVELS__MINIMAL__THINKING_BUDGET_TOKENS={{ dialectic_minimal_think | default(0) }}
DIALECTIC_LEVELS__MINIMAL__MAX_TOOL_ITERATIONS={{ dialectic_minimal_tools | default(1) }}

# Low: Quick responses with some tool use
DIALECTIC_LEVELS__LOW__PROVIDER={{ dialectic_low_provider | default('vllm') }}
DIALECTIC_LEVELS__LOW__MODEL={{ dialectic_low_model | default('kimi-k2.5') }}
DIALECTIC_LEVELS__LOW__THINKING_BUDGET_TOKENS={{ dialectic_low_think | default(0) }}
DIALECTIC_LEVELS__LOW__MAX_TOOL_ITERATIONS={{ dialectic_low_tools | default(3) }}

# Medium: Balanced reasoning
DIALECTIC_LEVELS__MEDIUM__PROVIDER={{ dialectic_medium_provider | default('vllm') }}
DIALECTIC_LEVELS__MEDIUM__MODEL={{ dialectic_medium_model | default('kimi-k2.5') }}
DIALECTIC_LEVELS__MEDIUM__THINKING_BUDGET_TOKENS={{ dialectic_medium_think | default(1024) }}
DIALECTIC_LEVELS__MEDIUM__MAX_TOOL_ITERATIONS={{ dialectic_medium_tools | default(5) }}

# High: Deeper reasoning
DIALECTIC_LEVELS__HIGH__PROVIDER={{ dialectic_high_provider | default('vllm') }}
DIALECTIC_LEVELS__HIGH__MODEL={{ dialectic_high_model | default('kimi-k2.5') }}
DIALECTIC_LEVELS__HIGH__THINKING_BUDGET_TOKENS={{ dialectic_high_think | default(1024) }}
DIALECTIC_LEVELS__HIGH__MAX_TOOL_ITERATIONS={{ dialectic_high_tools | default(8) }}

# Max: Maximum reasoning depth
DIALECTIC_LEVELS__MAX__PROVIDER={{ dialectic_max_provider | default('vllm') }}
DIALECTIC_LEVELS__MAX__MODEL={{ dialectic_max_model | default('kimi-k2.5') }}
DIALECTIC_LEVELS__MAX__THINKING_BUDGET_TOKENS={{ dialectic_max_think | default(2048) }}
DIALECTIC_LEVELS__MAX__MAX_TOOL_ITERATIONS={{ dialectic_max_tools | default(10) }}

# =============================================================================
# SUMMARY CONFIGURATION
# =============================================================================

SUMMARY_ENABLED={{ summary_enabled | default(true) | lower }}
SUMMARY_PROVIDER={{ summary_provider | default('vllm') }}
SUMMARY_MODEL={{ summary_model | default('kimi-k2.5') }}
SUMMARY_THINKING_BUDGET_TOKENS={{ summary_think_tokens | default(2000) }}
SUMMARY_MESSAGES_PER_SHORT_SUMMARY={{ summary_short_messages | default(20) }}
SUMMARY_MESSAGES_PER_LONG_SUMMARY={{ summary_long_messages | default(60) }}
SUMMARY_MAX_TOKENS_SHORT={{ summary_max_short | default(1000) }}
SUMMARY_MAX_TOKENS_LONG={{ summary_max_long | default(4000) }}

# =============================================================================
# DREAMER CONFIGURATION (Background Memory Synthesis)
# =============================================================================

DREAM_ENABLED={{ dream_enabled | default(true) | lower }}

# From .env: Uses anthropic with reasoning models
DREAM_PROVIDER={{ dream_provider | default('anthropic') }}
DREAM_MODEL={{ dream_model | default('claude-sonnet-4-20250514') }}

# Dream specialists
DREAM_DEDUCTION_MODEL={{ dream_deduction_model | default('claude-haiku-4-5') }}
DREAM_INDUCTION_MODEL={{ dream_induction_model | default('claude-haiku-4-5') }}
DREAM_SYNTHESIS_MODEL={{ dream_synthesis_model | default('claude-haiku-4-5') }}

# Dream behavior
DREAM_MAX_OUTPUT_TOKENS={{ dream_max_tokens | default(16384) }}
DREAM_THINKING_BUDGET_TOKENS={{ dream_think_tokens | default(8192) }}
DREAM_MAX_TOOL_ITERATIONS={{ dream_max_tools | default(20) }}
DREAM_HISTORY_TOKEN_LIMIT={{ dream_history_limit | default(16384) }}

# Schedule settings
DREAM_DOCUMENT_THRESHOLD={{ dream_doc_threshold | default(50) }}
DREAM_IDLE_TIMEOUT_MINUTES={{ dream_idle_timeout | default(60) }}
DREAM_MIN_HOURS_BETWEEN_DREAMS={{ dream_min_hours | default(8) }}

# Surprisal-based sampling
DREAM_SURPRISAL_ENABLED={{ dream_surprisal_enabled | default(false) | lower }}

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# JWT authentication
AUTH_USE_AUTH={{ auth_use_auth | default(false) | lower }}
AUTH_JWT_SECRET={{ auth_jwt_secret | default('') }}

# =============================================================================
# WEBHOOK CONFIGURATION
# =============================================================================

WEBHOOK_SECRET={{ webhook_secret | default('') }}
WEBHOOK_MAX_WORKSPACE_LIMIT={{ webhook_max_workspaces | default(10) }}

