# Test Environment Configuration Template
# Copy this file to .env.test and customize for your setup
# DO NOT commit .env.test with real credentials

# Database
HONCHO_DATABASE__CONNECTION_URI=postgresql+asyncpg://<user>:<password>@localhost:5433/test_db

# =============================================================================
# Embedding Provider Settings (for HONCHO_TEST_USE_OLLAMA=1)
# =============================================================================
# These are only used when running tests with HONCHO_TEST_USE_OLLAMA=1
# Default: mocked embeddings (fast, no setup required)

# Ollama settings (for real embedding tests)
HONCHO_LLM__EMBEDDING_PROVIDER=ollama
HONCHO_LLM__OLLAMA_BASE_URL=http://localhost:11434
HONCHO_LLM__OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest

# Deriver settings
HONCHO_DERIVER__ENABLED=true

# Vector store
HONCHO_VECTOR_STORE__PROVIDER=pgvector

# Cache
HONCHO_CACHE__ENABLED=false

# For CI/parallel tests, disable telemetry
HONCHO_TELEMETRY__ENABLED=false

# =============================================================================
# Running Tests
# =============================================================================
# Default (mocked embeddings - fast, no external services):
#   uv run pytest tests/ [--ignore=tests/sdk_typescript]
#
# With Ollama (real embeddings - requires ollama serve):
#   HONCHO_TEST_USE_OLLAMA=1 uv run pytest tests/ [--ignore=tests/sdk_typescript]
#
# Sequential-only (for tests with shared state):
#   uv run pytest tests/ -n 0 -m "sequential"
#
# TypeScript SDK Tests (see README below for requirements):
#   uv run pytest tests/sdk_typescript/ -v
#
# Load environment variables:
#   export $(grep -v '^#' .env.test | xargs) && uv run pytest tests/

# =============================================================================
# TypeScript SDK Tests (tests/sdk_typescript/)
# =============================================================================
# These require additional infrastructure:
#
# 1. bun (JavaScript runtime): https://bun.sh/docs/installation
#    - curl -fsSL https://bun.sh/install | bash
#    - Or: npm install -g bun
#
# 2. TypeScript SDK dependencies:
#    cd sdks/typescript && bun install
#
# 3. Test server setup (handled automatically by ts_test_server fixture):
#    - Starts a real Uvicorn HTTP server on a random port
#    - Uses the test database (same as Python tests)
#    - Runs the TypeScript test suite via subprocess
#
# The tests will fail if bun is not installed or node_modules is missing.
# To skip TypeScript tests: uv run pytest tests/ --ignore=tests/sdk_typescript
